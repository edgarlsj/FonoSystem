# Neon PostgreSQL — copie a connection string do console em console.neon.tech
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=<sua-senha-neon>

# JWT (gere uma nova chave segura em produção)
JWT_SECRET=fonosystem-jwt-secret-key-2026-change-this-in-production

# Timezone
TZ=America/Sao_Paulo
